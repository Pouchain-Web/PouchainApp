{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pouchain-web-navig",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    "crons": [ "* * * * *" ]
  }
}
